# ==============================================================================
# Solarway - Arquivo de Configuração de Ambiente (Exemplo)
# Copie este arquivo para .env e preencha com seus valores reais.
# Variáveis com valores padrão não precisam ser alteradas na maioria dos casos.
# ==============================================================================

# ── 1. Bancos de Dados (MySQL e Redis) ────────────────────────────────────────
DB_USERNAME=user_db
DB_PASSWORD=password
MYSQL_ROOT_PASSWORD=root_password   # Pode ser diferente do DB_PASSWORD para maior segurança em Prod

PORT_MYSQL=3307
PORT_REDIS=6379

PORT_BOT_REDIS=6380
REDIS_USER=default
REDIS_PASSWORD=default

PORT_MICROSERVICE_DB=3306

# ── 2. Backend (Monolito e Microserviços) ─────────────────────────────────────
EMAIL=dummy@email.com
EMAIL_PASSWORD=dummy
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

BACKEND_BASE_URL=http://localhost:8000
VITE_BACKEND_BASE_URL=http://localhost:8000/api
PORT_BACKEND_MONOLITH=8000
PORT_BACKEND_MICROSERVICE=8082

# ── 3. Automação e Bot WhatsApp (n8n + WAHA) ──────────────────────────────────
BOT_SECRET=solarize_whatsapp_bot_super_secret

PORT_WAHA=3000
PORT_N8N=5678

BACKEND_API_URL=http://backend-service:8000
WAHA_API_URL=http://bot-waha:3000

N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_PORT=5678
N8N_BASE_URL=http://localhost:5678/
N8N_WEBHOOK_URL=http://localhost:5678/

# Configurações do WAHA (valores padrão — mudar em produção segura)
WHATSAPP_HOOK_EVENTS=message
WHATSAPP_DEFAULT_ENGINE=GOWS
WHATSAPP_HOOK_URL=http://bot-n8n:5678/webhook/webhook
WAHA_NO_API_KEY=true
WAHA_DASHBOARD_NO_PASSWORD=true
WHATSAPP_SWAGGER_NO_PASSWORD=true

# ── 4. Web Scrapping (Batch Job) ───────────────────────────────────────────────
DB_HOST=mysql-db
DB_PORT=3306
DB_NAME=solarway

# ── 5. Frontend (Management System e Institucional) ───────────────────────────
PORT_MANAGEMENT_SYSTEM=8080
PORT_INSTITUTIONAL_WEBSITE=8081

# ── 6. Proxy Central (Nginx) ──────────────────────────────────────────────────
PORT_PROXY=80

# ── 7. Credenciais de Build e Imagens (GitHub Packages) ───────────────────────
GITHUB_USERNAME=seu_usuario
GITHUB_ACCESS_TOKEN=seu_token_ghp

# ── 8. Cloud AWS (Terraform e Data Lake) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
AWS_SESSION_TOKEN=dummy

BUCKET_NAME=solarway-datalake-silver