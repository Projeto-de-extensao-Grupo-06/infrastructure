        "jsCode": "const data = $input.item.json.state.data;\nconst billText = data.bill.replace(/[^0-9,]/g, '').replace(',', '.');\nconst bill = parseFloat(billText);\n\n// Cálculos Baseados no Site / BudgetCalcs\nconst consumptionKwh = bill / 0.90;\nconst kwp = consumptionKwh / (30 * 5.0 * 0.75);\nconst estimatedCost = kwp * 4500;\nconst estimatedSavings = bill * 0.95;\nconst paybackYears = estimatedCost / (estimatedSavings * 12);\n\nreturn { json: { ...$input.item.json, calcs: { consumptionKwh: Math.round(consumptionKwh), kwp: kwp.toFixed(2), estimatedCost: Math.round(estimatedCost), estimatedSavings: estimatedSavings.toFixed(2), paybackYears: paybackYears.toFixed(1) } } };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        528,
        1840
      ],
      "id": "efb694e9-5253-483a-8e83-23dc61f1a863",
      "name": "Calcular Estimativas"
