# env.bot.tmpl — Variáveis injetadas via SSM Association na EC2 do Bot
#
# NOTA ARQUITETURAL: Em PROD o bot está em instância SEPARADA do backend.
# A EC2 do chatbot está em subnet PRIVADA — sem IP público próprio.
# O acesso externo ao n8n e WAHA é feito via Nginx Proxy (ec2_nginx).
# O BACKEND_API_URL usa o IP PRIVADO do backend (cross-EC2, não hostname Docker).
# WAHA → n8n usa hostname Docker pois compartilham a mesma EC2 (mesma rede Docker).

# ── Backend (IP Privado da VPC) ───────────────────────────────────────────────
BACKEND_API_URL=http://${backend_1_ip}:8000
BOT_SECRET=${bot_secret}

# ── Credenciais para pull de imagens privadas ─────────────────────────────────
GITHUB_USERNAME=${github_username}
GITHUB_ACCESS_TOKEN=${github_access_token}

# ── n8n: URLs usando o Nginx Proxy como ingress público ──────────────────────
# Webhooks devem ser registrados no Nginx pois o chatbot não tem IP público
N8N_HOST=${nginx_public_ip}
N8N_PROTOCOL=http
N8N_PORT=5678
N8N_BASE_URL=http://${nginx_public_ip}/n8n/
N8N_WEBHOOK_URL=http://${nginx_public_ip}/
WEBHOOK_URL=http://${nginx_public_ip}/
N8N_PATH=/

# ── WAHA: hook interno Docker (WAHA e n8n na mesma EC2) ──────────────────────
WHATSAPP_HOOK_URL=http://bot-n8n:5678/webhook/webhook
WHATSAPP_DEFAULT_ENGINE=GOWS
WHATSAPP_HOOK_EVENTS=message
WAHA_NO_API_KEY=true
WAHA_DASHBOARD_NO_PASSWORD=true
WHATSAPP_SWAGGER_NO_PASSWORD=true

# ── Redis (mesmo host — Docker interno) ───────────────────────────────────────
REDIS_USER=${redis_user}
REDIS_PASSWORD=${redis_password}
PORT_BOT_REDIS=6380
PORT_N8N=5678
PORT_WAHA=3000

# ── Web Scrapping: DB via IP Privado ──────────────────────────────────────────
DB_HOST=${db_private_ip}
DB_PORT=3306
DB_NAME=solarway
DB_USERNAME=${db_username}
DB_PASSWORD=${db_password}
