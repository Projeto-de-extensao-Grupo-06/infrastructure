DB_PASSWORD=${db_password}

# Legacy/App Overrides
SPRING_DATASOURCE_URL=jdbc:mysql://${db_private_ip}:3306/solarway
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=${db_password}
REDIS_HOST=${db_private_ip}
