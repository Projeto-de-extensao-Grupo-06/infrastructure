# ==============================================================================
# Solarway - Arquivo de Configuração de Ambiente (Exemplo)
# Copie este arquivo para .env e preencha com seus valores reais.
# ==============================================================================

# ── 1. Bancos de Dados e Persistência ─────────────────────────────────────────
DB_USERNAME=user_db
DB_PASSWORD=password
PORT_MYSQL=3307
PORT_REDIS=6379

# ── 2. Backend (Monolito e Microserviços) ─────────────────────────────────────
# Configurações de e-mail para notificações
EMAIL=dummy@email.com
PASSWORD_EMAIL=dummy
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# Base URLs para o Monolito e Microserviço
BACKEND_BASE_URL=http://localhost:8000
VITE_BACKEND_BASE_URL=http://localhost:8000/api
PORT_BACKEND_MONOLITH=8000
PORT_BACKEND_MICROSERVICE=8082
PORT_MICROSERVICE_DB=3306

# ── 3. Automação e Bot WhatsApp (n8n + WAHA) ──────────────────────────────────
BOT_SECRET=solarize_whatsapp_bot_super_secret

# Portas dos serviços de Bot
PORT_WAHA=3000
PORT_N8N=5678
PORT_BOT_REDIS=6380

# Configurações de URL para o n8n (o bootstrap do QA sobrescreve estas)
# Localmente apontam para localhost
N8N_BASE_URL=http://localhost:5678/
N8N_WEBHOOK_URL=http://localhost:5678/

# ── 4. Frontend (Management System e Institucional) ───────────────────────────
PORT_MANAGEMENT_SYSTEM=8080
PORT_INSTITUTIONAL_WEBSITE=8081

# ── 5. Credenciais de Build e Imagens (GitHub Packages) ───────────────────────
# Obrigatório para pulls de pacotes privados da organização
GITHUB_USERNAME=seu_usuario
GITHUB_ACCESS_TOKEN=seu_token_ghp

# ── 6. Cloud AWS (Terraform e Data Lake) ──────────────────────────────────────
# Credenciais AWS para provisioning e acesso ao S3
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
AWS_SESSION_TOKEN=dummy

# Nome do bucket do Data Lake (Silver/Trusted)
BUCKET_NAME=solarway-datalake-silver

# Nome da chave .pem na AWS para acesso SSH/SCP
AWS_KEY_NAME=solarway
